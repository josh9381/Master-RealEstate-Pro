// Per-lead campaign tracking — records individual lead engagement with campaigns
model CampaignLead {
  id             String    @id @default(cuid())
  campaignId     String
  leadId         String
  organizationId String
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  convertedAt    DateTime?
  bouncedAt      DateTime?
  unsubscribedAt DateTime?
  status         CampaignLeadStatus @default(PENDING)
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  campaign       Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([leadId])
  @@index([organizationId])
  @@index([status])
}

// Aggregated campaign analytics — snapshot of campaign performance
model CampaignAnalytics {
  id               String   @id @default(cuid())
  campaignId       String   @unique
  organizationId   String
  totalSent        Int      @default(0)
  totalDelivered   Int      @default(0)
  totalOpened      Int      @default(0)
  totalClicked     Int      @default(0)
  totalConverted   Int      @default(0)
  totalBounced     Int      @default(0)
  totalUnsubscribed Int     @default(0)
  openRate         Float?   @default(0)
  clickRate        Float?   @default(0)
  conversionRate   Float?   @default(0)
  bounceRate       Float?   @default(0)
  revenue          Float?   @default(0)
  lastUpdatedAt    DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  campaign         Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([campaignId])
}

// Login history for session management — tracks user sessions across devices
model LoginHistory {
  id             String    @id @default(cuid())
  userId         String
  organizationId String
  ipAddress      String?
  userAgent      String?
  deviceType     String?
  browser        String?
  os             String?
  country        String?
  city           String?
  isActive       Boolean   @default(true)
  lastActiveAt   DateTime  @default(now())
  loggedOutAt    DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([isActive])
  @@index([userId, isActive])
  @@index([createdAt])
}

// Sprint 9.1 #102: Bounce suppression list — prevents sending to addresses that have bounced or reported spam
model EmailSuppression {
  id             String   @id @default(cuid())
  email          String
  reason         String   // 'bounce', 'spamreport', 'manual'
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([email])
}

// Follow-up reminder — tracks scheduled reminders with multi-channel delivery
model FollowUpReminder {
  id              String           @id @default(cuid())
  leadId          String
  userId          String
  organizationId  String
  title           String
  note            String?
  dueAt           DateTime
  status          ReminderStatus   @default(PENDING)
  priority        ReminderPriority @default(MEDIUM)
  // Delivery channels — which channels to fire when due
  channelInApp    Boolean          @default(true)
  channelEmail    Boolean          @default(false)
  channelSms      Boolean          @default(false)
  channelPush     Boolean          @default(false)
  // Recurrence (Phase 5.8)
  isRecurring     Boolean          @default(false)
  recurrencePattern RecurrencePattern?  // DAILY, WEEKLY, BIWEEKLY, MONTHLY, QUARTERLY, YEARLY, CUSTOM
  recurrenceInterval Int?               // For CUSTOM: every N days
  recurrenceEndDate  DateTime?          // Optional: stop recurring after this date
  recurrenceCount    Int?               // Optional: max number of occurrences
  occurrenceNumber   Int               @default(0) // Which occurrence this is (0 = first/original)
  parentReminderId   String?            // If this is a recurrence child, link to original
  // Tracking
  firedAt         DateTime?        // When the reminder was actually dispatched
  completedAt     DateTime?        // When user marked it complete / acted on it
  snoozedUntil    DateTime?        // If snoozed, new due date
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lead            Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([dueAt, status])
  @@index([leadId])
  @@index([organizationId])
  @@index([parentReminderId])
}

enum ReminderStatus {
  PENDING     // Not yet due
  FIRED       // Due time reached, notifications sent
  COMPLETED   // User acted on it
  SNOOZED     // Snoozed to a later time
  CANCELLED   // Cancelled by user
}

enum ReminderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Push subscription — stores browser push subscriptions per user
model PushSubscription {
  id              String   @id @default(cuid())
  userId          String
  organizationId  String
  endpoint        String   @unique
  p256dh          String   // Public key
  auth            String   // Auth secret
  userAgent       String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
}

// Phase 5.3: Report scheduling
model ReportSchedule {
  id              String            @id @default(cuid())
  savedReportId   String
  userId          String
  organizationId  String
  frequency       RecurrencePattern // DAILY, WEEKLY, BIWEEKLY, MONTHLY, QUARTERLY, YEARLY, CUSTOM
  customInterval  Int?              // For CUSTOM: every N days
  dayOfWeek       Int?              // 0-6 (Sun-Sat) for weekly schedules
  dayOfMonth      Int?              // 1-31 for monthly schedules
  timeOfDay       String            @default("08:00") // HH:mm in user's timezone
  timezone        String            @default("America/New_York")
  isActive        Boolean           @default(true)
  recipients      Json?             // Additional email recipients: string[]
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  runCount        Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  savedReport     SavedReport       @relation(fields: [savedReportId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reportHistory   ReportHistory[]

  @@index([organizationId])
  @@index([nextRunAt, isActive])
  @@index([userId])
}

// Phase 5.3: Generated report history (in-app storage)
model ReportHistory {
  id                String          @id @default(cuid())
  reportScheduleId  String
  savedReportId     String
  userId            String
  organizationId    String
  title             String
  generatedData     Json            // The report data snapshot
  fileUrl           String?         // S3/local URL for PDF if available
  sentTo            Json?           // Email addresses it was sent to
  status            String          @default("COMPLETED") // COMPLETED, FAILED
  errorMessage      String?
  createdAt         DateTime        @default(now())
  reportSchedule    ReportSchedule  @relation(fields: [reportScheduleId], references: [id], onDelete: Cascade)
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([reportScheduleId])
  @@index([createdAt])
}

// Phase 5.4: Goal setting & tracking
model Goal {
  id              String        @id @default(cuid())
  userId          String
  organizationId  String
  name            String
  metricType      GoalMetricType
  targetValue     Float
  currentValue    Float         @default(0)
  startDate       DateTime
  endDate         DateTime
  period          GoalPeriod    @default(MONTHLY)
  isActive        Boolean       @default(true)
  completedAt     DateTime?     // When goal was first reached
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId, isActive])
  @@index([endDate])
}

enum RecurrencePattern {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum GoalMetricType {
  LEADS_GENERATED
  DEALS_CLOSED
  REVENUE
  CONVERSION_RATE
  CALLS_MADE
  APPOINTMENTS_SET
  RESPONSE_TIME
  CUSTOM
}

enum GoalPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model LeadDocument {
  id              String       @id @default(cuid())
  leadId          String
  organizationId  String
  uploadedById    String
  filename        String       // Original filename for display
  storagePath     String       // Relative path within uploads/documents
  mimeType        String
  size            Int          // File size in bytes
  description     String?
  createdAt       DateTime     @default(now())

  lead            Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy      User         @relation("LeadDocumentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([organizationId])
}

// Phase 9.4: Audit log — records every significant action in the system
model AuditLog {
  id              String       @id @default(cuid())
  userId          String?
  organizationId  String
  action          AuditAction
  entityType      String       // e.g. "Lead", "Campaign", "User", "Settings"
  entityId        String?      // ID of the affected entity
  description     String       // Human-readable description
  ipAddress       String?
  userAgent       String?
  beforeData      Json?        // Snapshot before the change
  afterData       Json?        // Snapshot after the change
  metadata        Json?        // Extra context (e.g. bulk action count)
  createdAt       DateTime     @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum AuditAction {
  // Auth
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGED
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  // CRUD
  CREATED
  UPDATED
  DELETED
  // Settings
  SETTINGS_CHANGED
  SUBSCRIPTION_CHANGED
  // Team
  TEAM_MEMBER_INVITED
  TEAM_MEMBER_ROLE_CHANGED
  TEAM_MEMBER_REMOVED
  // Data operations
  DATA_IMPORTED
  DATA_EXPORTED
  DATA_MERGED
  BULK_ACTION
  BACKUP_CREATED
  // Admin
  SYSTEM_SETTINGS_CHANGED
  MAINTENANCE_ACTION
}

// Phase 9.5: Data backup tracking
model DataBackup {
  id              String       @id @default(cuid())
  organizationId  String
  createdById     String
  filename        String
  filePath        String
  sizeBytes       Int
  recordCount     Int          @default(0)
  status          String       @default("completed") // completed, failed, in_progress
  type            String       @default("manual")     // manual, automatic
  tables          Json?        // { tableName: recordCount } breakdown
  error           String?
  createdAt       DateTime     @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([status])
}

// Phase 9.7b: Support ticket system
model SupportTicket {
  id              String              @id @default(cuid())
  organizationId  String
  createdById     String
  assignedToId    String?
  subject         String
  description     String
  status          TicketStatus        @default(OPEN)
  priority        TicketPriority      @default(MEDIUM)
  category        String?
  closedAt        DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages        TicketMessage[]

  @@index([organizationId, status])
  @@index([createdById])
  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
}

model TicketMessage {
  id              String       @id @default(cuid())
  ticketId        String
  userId          String
  content         String
  isStaffReply    Boolean      @default(false)
  createdAt       DateTime     @default(now())

  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageTemplateTier {
  SYSTEM
  ORGANIZATION
  TEAM
  PERSONAL
}

// Phase 9.7d: Documentation articles
model DocumentationArticle {
  id              String       @id @default(cuid())
  organizationId  String?      // null = global/system article
  title           String
  slug            String       @unique
  content         String       // Markdown content
  category        String
  tags            String[]     @default([])
  order           Int          @default(0)
  isPublished     Boolean      @default(false)
  viewCount       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([category])
  @@index([isPublished])
  @@index([slug])
}
