# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=8000
APP_NAME=RealEstate Pro
LOG_LEVEL=debug

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/realestate?schema=public"

# =============================================================================
# AUTHENTICATION — REQUIRED
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Must be at least 32 characters. Use different secrets for each.
JWT_ACCESS_SECRET=GENERATE_YOUR_OWN_32_CHAR_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_YOUR_OWN_32_CHAR_SECRET_HERE

# =============================================================================
# URLS
# =============================================================================
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:8000

# =============================================================================
# ENCRYPTION — REQUIRED
# =============================================================================
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes). If lost, all encrypted credentials are unrecoverable.
MASTER_ENCRYPTION_KEY=GENERATE_YOUR_OWN_64_CHAR_HEX_KEY_HERE

# =============================================================================
# AI — OpenAI
# =============================================================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=org-your-openai-org-id-here
OPENAI_MODEL=gpt-4-turbo-preview
AI_LOG_LEVEL=info
# Monthly spend alert threshold in dollars (default: 100)
AI_SPEND_ALERT_THRESHOLD=100

# =============================================================================
# VOICE AI — Vapi.ai
# =============================================================================
# Get from: https://vapi.ai/dashboard
VAPI_API_KEY=your-vapi-api-key-here
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret-here

# =============================================================================
# EMAIL — SendGrid
# =============================================================================
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_WEBHOOK_VERIFICATION_KEY=your-sendgrid-webhook-verification-key-here
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=RealEstate Pro
UNSUBSCRIBE_EMAIL=unsubscribe@yourdomain.com
# Maximum emails per day (default: 1000)
DAILY_EMAIL_LIMIT=1000

# =============================================================================
# SMS — Twilio
# =============================================================================
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC-your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+15551234567

# =============================================================================
# BILLING — Stripe
# =============================================================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here
# Stripe Price IDs for each subscription tier (create in Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=price_starter_id_here
STRIPE_PRICE_PROFESSIONAL=price_professional_id_here
STRIPE_PRICE_ELITE=price_elite_id_here
STRIPE_PRICE_TEAM=price_team_id_here

# =============================================================================
# PUSH NOTIFICATIONS — Web Push (VAPID)
# =============================================================================
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:admin@yourdomain.com

# =============================================================================
# CACHING — Redis (Optional)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# =============================================================================
# MONITORING (Optional)
# =============================================================================
# Sentry error tracking — Get from: https://sentry.io
# SENTRY_DSN=https://your-sentry-dsn-here

# API Keys (Users will provide their own - BYOK)
# These are just for reference, users add them in the app
