# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.
# All frontend env vars must be prefixed with VITE_ to be exposed to the client.

# API URL — base URL for backend API requests
VITE_API_URL=http://localhost:8000/api

# API Base URL — root backend URL (used for WebSocket connections, uploads, etc.)
VITE_API_BASE_URL=http://localhost:8000

# Application name — displayed in the UI header and page titles
VITE_APP_NAME=RealEstate Pro
